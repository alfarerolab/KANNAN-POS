model producto {
  id                    String                  @id @default(cuid())
  nombre                String
  descripcion           String?                 @db.Text
  precio                Decimal?                @db.Decimal(10, 2)
  precioCosto           Decimal?                @db.Decimal(10, 2)
  tipoVenta             producto_tipoVenta      @default(UNIDAD)
  precioPorKilo         Decimal?                @db.Decimal(10, 2)
  precioPorGramo        Decimal?                @db.Decimal(10, 4)
  precioPorMetro        Decimal?                @db.Decimal(10, 2)
  precioPorLitro        Decimal?                @db.Decimal(10, 2)
  unidadBase            String?
  unidadVenta           String?
  factorConversion      Decimal?                @db.Decimal(10, 4)
  codigoBarras          String?                 @unique(map: "Producto_codigoBarras_key")
  sku                   String?
  imagen                String?                 @db.Text
  enStock               Decimal                 @default(0.000) @db.Decimal(10, 3)
  stockMinimo           Decimal                 @default(0.000) @db.Decimal(10, 3)
  requiereBalanza       Boolean                 @default(false)
  pesoAproximado        Decimal?                @db.Decimal(10, 3)
  activo                Boolean                 @default(true)
  empresaId             String
  categoriaId           String?
  proveedorId           String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  imagenCodigoBarras    String?                 @db.Text
  esExentoIva           Boolean                 @default(false)
  incluyeIva            Boolean                 @default(true)
  tarifaIva             Decimal                 @default(19.00) @db.Decimal(5, 2)
  precioSugerido        Decimal?                @db.Decimal(10, 2)
  fechasVencimiento     String?                 @db.LongText
  manejaVencimiento     Boolean                 @default(false)

  // ─── Productos Compuestos (Combos) ─────────────────
  esCombo               Boolean                 @default(false)
  precioEspecial        Decimal?                @db.Decimal(10, 2)   // Precio alternativo (ej: fin de semana)
  diasPrecioEspecial    String?                 // JSON: ["VIERNES","SABADO","DOMINGO"]

  // ─── Relaciones existentes ─────────────────────────
  itemsVenta            ItemVenta[]
  movimientobodega      MovimientoBodega[]
  movimientosInventario MovimientoInventario[]
  pedidorestauranteitem PedidoRestauranteItem[]
  categoria             categoria?              @relation(fields: [categoriaId], references: [id], map: "Producto_categoriaId_fkey")
  empresa               empresa                 @relation(fields: [empresaId], references: [id], onDelete: Cascade, map: "Producto_empresaId_fkey")
  proveedor             proveedor?              @relation(fields: [proveedorId], references: [id], map: "Producto_proveedorId_fkey")
  varianteproducto      VarianteProducto[]
  consumosInternos      ConsumoInventarioServicio[] // Consumos de inventario internos ligados a servicios de peluquería

  // ─── Relaciones de Combos ──────────────────────────
  itemsComanda          ComandaItem[]
  componentes           ComponenteProducto[]    // Componentes de este combo
  usadoEnCombos         ComponenteProducto[]    @relation("ComponenteRef") // Combos que usan este producto

  @@index([categoriaId], map: "Producto_categoriaId_idx")
  @@index([empresaId], map: "Producto_empresaId_idx")
  @@index([proveedorId], map: "Producto_proveedorId_idx")
}

model ComponenteProducto {
