model CajaTurno {
  id        String    @id @default(cuid())
  empresaId String
  usuarioId String
  abiertaEn          DateTime  @default(now())
  cerradaEn          DateTime?
  montoInicial       Decimal   @default(0.00) @db.Decimal(10, 2)
  montoFinalEsperado Decimal?  @db.Decimal(10, 2)
  montoFinalReal     Decimal?  @db.Decimal(10, 2)
  diferencia         Decimal?  @db.Decimal(10, 2)
  notas              String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  cajaId    String?
  caja      Caja?   @relation(fields: [cajaId], references: [id], onDelete: Cascade)
  empresa empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario usuario @relation(fields: [usuarioId], references: [id])
  gastos  Gasto[]

  @@index([empresaId, cerradaEn])
  @@index([cajaId])
  @@map("cajaturno")
}

model CategoriaGasto {
  id        String   @id @default(cuid())
  nombre    String
  empresaId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gastos    Gasto[]

  empresa empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@map("categoriagasto")
}

model Gasto {
  id               String         @id @default(cuid())
  concepto         String
  monto            Decimal        @db.Decimal(10, 2)
  fecha            DateTime       @default(now())
  metodoPago       String?
  categoriaId      String?
  cajaTurnoId      String?
  usuarioId        String
  empresaId        String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  cajaId           String?
  caja             Caja?          @relation(fields: [cajaId], references: [id])
  categoria CategoriaGasto? @relation(fields: [categoriaId], references: [id])
  cajaTurno CajaTurno?     @relation(fields: [cajaTurnoId], references: [id])
  usuario   usuario        @relation(fields: [usuarioId], references: [id])
  empresa   empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, fecha])
  @@index([cajaTurnoId])
  @@index([cajaId])
  @@map("gasto")
}

model Caja {
  id        String      @id @default(cuid())
  nombre    String
  empresaId String
  activa    Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  empresa   empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  turnos    CajaTurno[]
  ventas    venta[]
  gastos    Gasto[]

  @@index([empresaId])
  @@map("caja")
}

