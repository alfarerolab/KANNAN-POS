  estado    ComandaEstado @default(ABIERTA)
  notas     String?       @db.Text
  total     Decimal       @default(0.00) @db.Decimal(10, 2)
  ventaId   String?       @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  empresa empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente cliente?      @relation(fields: [clienteId], references: [id])
  usuario usuario       @relation("ComandaCajero", fields: [usuarioId], references: [id])
  items   ComandaItem[]
  venta   venta?        @relation(fields: [ventaId], references: [id])

  @@index([empresaId, estado])
  @@index([clienteId])
  @@index([usuarioId])
  @@map("comanda")
}

model ComandaItem {
  id         String   @id @default(cuid())
  comandaId  String
  servicioId String?
  productoId String?
  empleadoId String?  // Empleado que realizó el servicio (si es servicio)
  precio     Decimal  @db.Decimal(10, 2)
  notas      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  comanda          Comanda                      @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  servicio         servicio?                    @relation(fields: [servicioId], references: [id])
  producto         producto?                    @relation(fields: [productoId], references: [id])
  empleado         usuario?                     @relation("ComandaItemEmpleado", fields: [empleadoId], references: [id])
  consumosInternos ConsumoInventarioServicio[]

  @@index([comandaId])
  @@index([servicioId])
  @@index([empleadoId])
  @@map("comandaitem")
}

model ConsumoInventarioServicio {
  id            String   @id @default(cuid())
  comandaItemId String
  productoId    String
  cantidad      Decimal  @db.Decimal(10, 3)
  notas         String?
  createdAt     DateTime @default(now())

  comandaItem ComandaItem @relation(fields: [comandaItemId], references: [id], onDelete: Cascade)
  producto    producto    @relation(fields: [productoId], references: [id])

  @@index([comandaItemId])
  @@index([productoId])
  @@map("consumoinventarioservicio")
}

enum ComandaEstado {
  ABIERTA
  CERRADA
  CANCELADA
}