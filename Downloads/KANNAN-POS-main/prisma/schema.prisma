generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model MovimientoInventario {
  id                 String                   @id @default(cuid())
  fechaMovimiento    DateTime                 @default(now())
  productoId         String
  usuarioId          String
  cantidad           Int
  tipo               TipoMovimientoInventario
  stockPrevio        Int
  stockNuevo         Int
  motivo             String                   @default("")
  createdAt          DateTime                 @default(now()) @map("fechaCreacion")
  updatedAt          DateTime                 @updatedAt @map("fechaActualizacion")
  producto           producto                 @relation(fields: [productoId], references: [id], onDelete: Cascade)
  usuario            usuario                  @relation(fields: [usuarioId], references: [id])

  @@index([productoId], map: "movimientos_inventario_productoId_fkey")
  @@index([usuarioId], map: "movimientos_inventario_usuarioId_fkey")
  @@map("movimientos_inventario")
}

model ActividadUsuario {
  id        String   @id @default(cuid())
  usuarioId String
  empresaId String
  accion    String
  detalles  String?  @db.LongText
  timestamp DateTime @default(now())
  ipAddress String?
  userAgent String?
  empresa   empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario   usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([empresaId])
  @@index([timestamp])
  @@index([accion])
  @@map("actividad_usuario")
}

model MetaEmpresa {
  id                 String    @id @default(cuid())
  empresaId          String
  periodo            String
  objetivo           Float
  createdAt          DateTime  @default(now()) @map("fechaCreacion")
  updatedAt          DateTime  @updatedAt @map("fechaActualizacion")
  activa             Boolean   @default(true)
  cantidadVentas     Int       @default(0)
  colorProgress      String?   @default("#3b82f6")
  descripcion        String?
  notificarEn        Int?      @default(80)
  progresoActual     Float     @default(0)
  tipo               TipoMeta  @default(INGRESOS)
  ultimoCalculado    DateTime?
  empresa            empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, periodo])
  @@index([empresaId])
  @@index([activa])
  @@map("metas_empresa")
}

model AplicacionPlantilla {
  id                     String                 @id @default(cuid())
  plantillaId            String
  empresaId              String
  aplicadoPor            String?
  fechaAplicacion        DateTime               @default(now())
  empresa                empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade, map: "AplicacionPlantilla_empresaId_fkey")
  plantillaconfiguracion PlantillaConfiguracion @relation(fields: [plantillaId], references: [id], onDelete: Cascade, map: "AplicacionPlantilla_plantillaId_fkey")

  @@index([empresaId], map: "AplicacionPlantilla_empresaId_idx")
  @@index([plantillaId], map: "AplicacionPlantilla_plantillaId_idx")
  @@map("aplicacionplantilla")
}

model AuditoriaLog {
  id                String              @id @default(cuid())
  tabla             String
  registroId        String
  accion            auditorialog_accion
  datosAnteriores   String?             @db.LongText
  datosNuevos       String?             @db.LongText
  cambiosRealizados String?             @db.LongText
  usuarioId         String?
  usuarioEmail      String?
  usuarioRol        String?
  empresaId         String?
  direccionIP       String?
  userAgent         String?
  notas             String?             @db.Text
  createdAt         DateTime            @default(now())
  empresa           empresa?            @relation(fields: [empresaId], references: [id], map: "AuditoriaLog_empresaId_fkey")

  @@index([createdAt], map: "AuditoriaLog_createdAt_idx")
  @@index([empresaId], map: "AuditoriaLog_empresaId_idx")
  @@index([tabla, registroId], map: "AuditoriaLog_tabla_registroId_idx")
  @@index([usuarioId], map: "AuditoriaLog_usuarioId_idx")
  @@map("auditorialog")
}

model bodega {
  id               String             @id @default(cuid())
  nombre           String
  descripcion      String?
  ubicacion        String?
  activa           Boolean            @default(true)
  empresaId        String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime                @updatedAt
  empresa          empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade, map: "Bodega_empresaId_fkey")
  movimientos      MovimientoBodega[]

  @@index([empresaId], map: "Bodega_empresaId_idx")
}

model categoria {
  id          String     @id @default(cuid())
  nombre      String
  descripcion String?
  empresaId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime                @updatedAt
  empresa     empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade, map: "Categoria_empresaId_fkey")
  productos   producto[]
  servicios   servicio[]

  @@index([empresaId], map: "Categoria_empresaId_idx")
}

model cita {
  id           String        @id @default(cuid())
  fechaHora    DateTime
  duracion     Int
  estado       cita_estado   @default(PROGRAMADA)
  notas        String?       @db.Text
  recordatorio Boolean       @default(true)
  clienteId    String
  servicioId   String
  empleadoId   String?
  empresaId    String
  ventaId      String?       @unique(map: "Cita_ventaId_key")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime                @updatedAt
  cliente      cliente       @relation(fields: [clienteId], references: [id], map: "Cita_clienteId_fkey")
  usuario      usuario?      @relation(fields: [empleadoId], references: [id], map: "Cita_empleadoId_fkey")
  empresa      empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade, map: "Cita_empresaId_fkey")
  servicio     servicio      @relation(fields: [servicioId], references: [id], map: "Cita_servicioId_fkey")
  venta        venta?        @relation(fields: [ventaId], references: [id], map: "Cita_ventaId_fkey")
  citamascota  CitaMascota[]

  @@index([clienteId], map: "Cita_clienteId_idx")
  @@index([empleadoId], map: "Cita_empleadoId_idx")
  @@index([empresaId], map: "Cita_empresaId_idx")
  @@index([fechaHora], map: "Cita_fechaHora_idx")
  @@index([servicioId], map: "Cita_servicioId_idx")
}

model CitaMascota {
  id             String    @id @default(cuid())
  citaId         String
  mascotaId      String
  motivoConsulta String    @db.Text
  diagnostico    String?   @db.Text
  tratamiento    String?   @db.Text
  proximaCita    DateTime?
  createdAt      DateTime  @default(now())
  cita           cita      @relation(fields: [citaId], references: [id], onDelete: Cascade, map: "CitaMascota_citaId_fkey")
  mascota        mascota   @relation(fields: [mascotaId], references: [id], onDelete: Cascade, map: "CitaMascota_mascotaId_fkey")

  @@unique([citaId, mascotaId], map: "CitaMascota_citaId_mascotaId_key")
  @@index([citaId], map: "CitaMascota_citaId_idx")
  @@index([mascotaId], map: "CitaMascota_mascotaId_idx")
  @@map("citamascota")
}

model cliente {
  id                String              @id @default(cuid())
  nombre            String
  email             String?
  telefono          String?
  direccion         String?
  empresaId         String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  cita              cita[]
  empresa           empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade, map: "Cliente_empresaId_fkey")
  mascota           mascota[]
  pedidorestaurante PedidoRestaurante[]
  venta             venta[]
  comandas          Comanda[]

  @@index([empresaId], map: "Cliente_empresaId_idx")
}

model ConfiguracionEmpresa {
  id                          String                           @id @default(cuid())
  empresaId                   String                           @unique(map: "ConfiguracionEmpresa_empresaId_key")
  tipoNegocio                 configuracionempresa_tipoNegocio
  habilitarServicios          Boolean                          @default(false)
  habilitarCitas              Boolean                          @default(false)
  habilitarVariantes          Boolean                          @default(false)
  habilitarRecetas            Boolean                          @default(false)
  habilitarLotes              Boolean                          @default(false)
  habilitarVencimientos       Boolean                          @default(false)
  habilitarMascotas           Boolean                          @default(false)
  habilitarInventarioAvanzado Boolean                          @default(false)
  habilitarReportes           Boolean                          @default(false)
  habilitarMultiUsuarios      Boolean                          @default(false)
  configuracionPos            String?                          @db.LongText
  configuracionFactura        String?                          @db.LongText
  configuracionInventario     String?                          @db.LongText
  createdAt                   DateTime                         @default(now())
  updatedAt                   DateTime                @updatedAt
  metaDiariaVentas            Float?
  metaMensualVentas           Float?
  metaSemanalVentas           Float?
  empresa                     empresa                          @relation(fields: [empresaId], references: [id], onDelete: Cascade, map: "ConfiguracionEmpresa_empresaId_fkey")

  @@map("configuracionempresa")
}

model EmpleadoServicio {
  id              String   @id @default(cuid())
  usuarioId       String
  servicioId      String
  activo          Boolean  @default(true)
  fechaAsignacion DateTime @default(now())
  servicio        servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade, map: "EmpleadoServicio_servicioId_fkey")
  usuario         usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade, map: "EmpleadoServicio_usuarioId_fkey")

  @@unique([usuarioId, servicioId], map: "EmpleadoServicio_usuarioId_servicioId_key")
  @@index([servicioId], map: "EmpleadoServicio_servicioId_idx")
  @@index([usuarioId], map: "EmpleadoServicio_usuarioId_idx")
  @@map("empleadoservicio")
}

model empresa {
  id                   String                @id @default(cuid())
  nombre               String
  email                String?               @unique
  telefono             String?
  direccion            String?
  logo                 String?               @db.Text
  tipoNegocio          empresa_tipoNegocio   @default(OTRO)
  activa               Boolean               @default(true)
  bodegaHabilitada     Boolean               @default(false)
  fechaVencimiento     DateTime?
  notaDesactivacion    String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  ciudad               String?
  departamento         String?
  imagenBanner         String?               @db.Text
  logoSecundario       String?               @db.Text
  nit                  String?               @unique(map: "Empresa_nit_key")
  nombreComercial      String?
  pais                 String?               @default("Colombia")
  actividadesUsuario     ActividadUsuario[]
  aplicacionesPlantilla  AplicacionPlantilla[]
  auditoriaLogs          AuditoriaLog[]
  bodegas                bodega[]
  categorias             categoria[]
  citas                  cita[]
  clientes               cliente[]
  configuracion          ConfiguracionEmpresa?
  mascotas               mascota[]
  mesasRestaurante       MesaRestaurante[]
  metas                  MetaEmpresa[]
  metricasUso            MetricaUso[]
  pedidosRestaurante     PedidoRestaurante[]
  productos              producto[]
  proveedores            proveedor[]
  servicios              servicio[]
  suscripciones          suscripcion[]
  terminales             terminal[]
  unidadesMedida         UnidadMedida[]
  usuarios               usuario[]
  ventas                 venta[]
  cajas                  Caja[]
  cajaTurnos             CajaTurno[]
  categoriasGasto        CategoriaGasto[]
  gastos                 Gasto[]
  comandas               Comanda[]
}

model ItemVenta {
  id               String             @id @default(cuid())
  cantidad         Decimal            @db.Decimal(10, 3)
  cantidadEntera   Int?
  peso             Decimal?           @db.Decimal(10, 3)
  medida           Decimal?           @db.Decimal(10, 3)
  comisionPagada   Boolean            @default(false)
  unidadMedida     String?
  precio           Decimal            @db.Decimal(10, 2)
  subtotal         Decimal            @db.Decimal(10, 2)
  ventaId          String
  productoId       String?
  servicioId       String?
  varianteId       String?
  empleadoId       String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime                @updatedAt
  producto         producto?          @relation(fields: [productoId], references: [id], map: "ItemVenta_productoId_fkey")
  servicio         servicio?          @relation(fields: [servicioId], references: [id], map: "ItemVenta_servicioId_fkey")
  variante         VarianteProducto?  @relation(fields: [varianteId], references: [id], map: "ItemVenta_varianteId_fkey")
  venta            venta              @relation(fields: [ventaId], references: [id], onDelete: Cascade, map: "ItemVenta_ventaId_fkey")
  empleado         usuario?           @relation("ItemVentaEmpleado", fields: [empleadoId], references: [id])
  itemventamascota ItemVentaMascota[]

  @@index([productoId], map: "ItemVenta_productoId_idx")
  @@index([servicioId], map: "ItemVenta_servicioId_idx")
  @@index([varianteId], map: "ItemVenta_varianteId_fkey")
  @@index([ventaId], map: "ItemVenta_ventaId_idx")
  @@index([empleadoId], map: "ItemVenta_empleadoId_idx")
  @@map("itemventa")
}

model ItemVentaMascota {
  id          String    @id @default(cuid())
  itemVentaId String
  mascotaId   String
  diagnostico String?   @db.Text
  tratamiento String?   @db.Text
  proximaCita DateTime?
  createdAt   DateTime  @default(now())
  itemventa   ItemVenta @relation(fields: [itemVentaId], references: [id], onDelete: Cascade, map: "ItemVentaMascota_itemVentaId_fkey")
  mascota     mascota   @relation(fields: [mascotaId], references: [id], onDelete: Cascade, map: "ItemVentaMascota_mascotaId_fkey")

  @@unique([itemVentaId, mascotaId], map: "ItemVentaMascota_itemVentaId_mascotaId_key")
  @@index([itemVentaId], map: "ItemVentaMascota_itemVentaId_idx")
  @@index([mascotaId], map: "ItemVentaMascota_mascotaId_idx")
  @@map("itemventamascota")
}

model mascota {
  id               String             @id @default(cuid())
  nombre           String
  especie          String
  raza             String?
  edad             Int?
  peso             Decimal?           @db.Decimal(5, 2)
  sexo             String?
  color            String?
  microchip        String?            @unique(map: "Mascota_microchip_key")
  historialMedico  String?            @db.Text
  alergias         String?            @db.Text
  medicamentos     String?            @db.Text
  observaciones    String?            @db.Text
  activo           Boolean            @default(true)
  clienteId        String
  empresaId        String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime                @updatedAt
  citas            CitaMascota[]
  itemsVenta       ItemVentaMascota[]
  cliente          cliente            @relation(fields: [clienteId], references: [id], onDelete: Cascade, map: "Mascota_clienteId_fkey")
  empresa          empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade, map: "Mascota_empresaId_fkey")

  @@index([clienteId], map: "Mascota_clienteId_idx")
  @@index([empresaId], map: "Mascota_empresaId_idx")
}

model MesaRestaurante {
  id                    String                  @id @default(cuid())
  nombre                String
  capacidad             Int                     @default(4)
  ubicacion             String?
  activa                Boolean                 @default(true)
  estado                mesarestaurante_estado  @default(LIBRE)
  empresaId             String
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  empresa               empresa                 @relation(fields: [empresaId], references: [id], onDelete: Cascade, map: "MesaRestaurante_empresaId_fkey")
  pedidos               PedidoMesaRestaurante[]

  @@unique([empresaId, nombre], map: "MesaRestaurante_empresaId_nombre_key")
  @@index([empresaId], map: "MesaRestaurante_empresaId_idx")
  @@index([estado], map: "MesaRestaurante_estado_idx")
  @@map("mesarestaurante")
}

model MetricaUso {
  id           String                  @id @default(cuid())
  tipo         metricauso_tipo
  entidad      String
  entidadId    String
  evento       String
  datos        String?                 @db.LongText
  valor        Int?
  valorDecimal Decimal?                @db.Decimal(10, 2)
  empresaId    String?
  usuarioId    String?
  tipoNegocio  metricauso_tipoNegocio?
  createdAt    DateTime                @default(now()) @map("fecha")
  fechaMes     String
  fechaDia     String
  empresa      empresa?                @relation(fields: [empresaId], references: [id], onDelete: Cascade, map: "MetricaUso_empresaId_fkey")

  @@index([empresaId], map: "MetricaUso_empresaId_idx")
  @@index([fechaDia], map: "MetricaUso_fechaDia_idx")
  @@index([fechaMes], map: "MetricaUso_fechaMes_idx")
  @@index([tipoNegocio], map: "MetricaUso_tipoNegocio_idx")
  @@index([tipo, entidad], map: "MetricaUso_tipo_entidad_idx")
  @@map("metricauso")
}

model MovimientoBodega {
  id               String                @id @default(cuid())
  tipo             movimientobodega_tipo
  cantidad         Int
  peso             Decimal?              @db.Decimal(10, 3)
  motivo           String
  varianteId       String?
  observaciones    String?               @db.Text
  productoId       String
  bodegaId         String
  usuarioId        String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime                @updatedAt
  bodega           bodega                @relation(fields: [bodegaId], references: [id], onDelete: Cascade, map: "MovimientoBodega_bodegaId_fkey")
  producto         producto              @relation(fields: [productoId], references: [id], map: "MovimientoBodega_productoId_fkey")
  usuario          usuario               @relation(fields: [usuarioId], references: [id], map: "MovimientoBodega_usuarioId_fkey")
  varianteproducto VarianteProducto?     @relation(fields: [varianteId], references: [id], map: "MovimientoBodega_varianteId_fkey")

  @@index([bodegaId], map: "MovimientoBodega_bodegaId_idx")
  @@index([productoId], map: "MovimientoBodega_productoId_idx")
  @@index([usuarioId], map: "MovimientoBodega_usuarioId_idx")
  @@index([varianteId], map: "MovimientoBodega_varianteId_fkey")
  @@map("movimientobodega")
}

model PagoVenta {
  id            String               @id @default(cuid())
  ventaId       String
  metodoPago    pagoventa_metodoPago
  monto         Decimal              @db.Decimal(10, 2)
  referencia    String?
  notas         String?
  createdAt     DateTime             @default(now()) @map("fechaCreacion")
  venta         venta                @relation(fields: [ventaId], references: [id], onDelete: Cascade, map: "PagoVenta_ventaId_fkey")

  @@index([ventaId], map: "PagoVenta_ventaId_idx")
  @@map("pagoventa")
}

model PagoVentaFiada {
  id         String   @id @default(cuid())
  ventaId    String
  monto      Decimal  @db.Decimal(10, 2)
  metodoPago String
  referencia String?
  notas      String?  @db.Text
  usuarioId  String?
  fechaPago  DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime                @updatedAt
  venta      venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade, map: "PagoVentaFiada_ventaId_fkey")

  @@index([fechaPago], map: "PagoVentaFiada_fechaPago_idx")
  @@index([ventaId], map: "PagoVentaFiada_ventaId_idx")
  @@map("pagoventafiada")
}

model PedidoMesaRestaurante {
  id                String            @id @default(cuid())
  pedidoId          String
  mesaId            String
  esPrincipal       Boolean           @default(false)
  createdAt         DateTime          @default(now())
  mesa              MesaRestaurante   @relation(fields: [mesaId], references: [id], onDelete: Cascade, map: "PedidoMesaRestaurante_mesaId_fkey")
  pedido            PedidoRestaurante @relation(fields: [pedidoId], references: [id], onDelete: Cascade, map: "PedidoMesaRestaurante_pedidoId_fkey")

  @@unique([pedidoId, mesaId], map: "PedidoMesaRestaurante_pedidoId_mesaId_key")
  @@index([mesaId], map: "PedidoMesaRestaurante_mesaId_idx")
  @@map("pedidomesarestaurante")
}

model PedidoRestaurante {
  id                    String                   @id @default(cuid())
  empresaId             String
  usuarioId             String
  clienteId             String?
  ventaId               String?                  @unique(map: "PedidoRestaurante_ventaId_key")
  estado                pedidorestaurante_estado @default(ABIERTO)
  nombreCuenta          String?
  notas                 String?                  @db.Text
  comensales            Int                      @default(1)
  subtotal              Decimal                  @default(0.00) @db.Decimal(10, 2)
  impuesto              Decimal                  @default(0.00) @db.Decimal(10, 2)
  total                 Decimal                  @default(0.00) @db.Decimal(10, 2)
  fechaFacturacion      DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                @updatedAt
  mesas                 PedidoMesaRestaurante[]
  cliente               cliente?                 @relation(fields: [clienteId], references: [id], map: "PedidoRestaurante_clienteId_fkey")
  empresa               empresa                  @relation(fields: [empresaId], references: [id], onDelete: Cascade, map: "PedidoRestaurante_empresaId_fkey")
  usuario               usuario                  @relation(fields: [usuarioId], references: [id], map: "PedidoRestaurante_usuarioId_fkey")
  venta                 venta?                   @relation(fields: [ventaId], references: [id], map: "PedidoRestaurante_ventaId_fkey")
  items                 PedidoRestauranteItem[]

  @@index([clienteId], map: "PedidoRestaurante_clienteId_idx")
  @@index([empresaId], map: "PedidoRestaurante_empresaId_idx")
  @@index([estado], map: "PedidoRestaurante_estado_idx")
  @@index([usuarioId], map: "PedidoRestaurante_usuarioId_idx")
  @@map("pedidorestaurante")
}

model PedidoRestauranteItem {
  id                String                                  @id @default(cuid())
  pedidoId          String
  productoId        String
  nombreProducto    String
  cantidad          Int                                     @default(1)
  precioUnitario    Decimal                                 @db.Decimal(10, 2)
  subtotal          Decimal                                 @db.Decimal(10, 2)
  notas             String?                                 @db.Text
  esCortesia        Boolean                                 @default(false)  // Cortesía: precio $0 pero descuenta stock
  createdAt         DateTime                                @default(now())
  updatedAt         DateTime                @updatedAt
  estacion          pedidorestauranteitem_estacion          @default(COCINA)
  estadoPreparacion pedidorestauranteitem_estadoPreparacion @default(PENDIENTE)
  fechaEntrega      DateTime?
  fechaListo        DateTime?
  fechaSolicitud    DateTime                                @default(now())
  pedido            PedidoRestaurante                       @relation(fields: [pedidoId], references: [id], onDelete: Cascade, map: "PedidoRestauranteItem_pedidoId_fkey")
  producto          producto                                @relation(fields: [productoId], references: [id], map: "PedidoRestauranteItem_productoId_fkey")

  @@index([estacion, estadoPreparacion], map: "PedidoRestauranteItem_estacion_estadoPreparacion_idx")
  @@index([pedidoId], map: "PedidoRestauranteItem_pedidoId_idx")
  @@index([productoId], map: "PedidoRestauranteItem_productoId_idx")
  @@map("pedidorestauranteitem")
}

model plan {
  id                    String        @id @default(cuid())
  nombre                String
  descripcion           String?       @db.Text
  precio                Decimal       @db.Decimal(10, 2)
  meses                 Int
  activo                Boolean       @default(true)
